# Gemini 設定（デフォルトかつ唯一の LLM プロバイダ）
LLM_PROVIDER=google
LLM_MODEL_NAME=gemini-3.1-flash-lite-preview
GOOGLE_AI_API_KEY=your_google_ai_api_key_here

# Flask / Session 秘密鍵（長いランダム文字列に置き換えてください）
SECRET_KEY=put_a_long_random_secret_here

# 互換用フィールド（現在の Gemini ランタイムでは使わないので空でよい）
LLM_API_KEY=
LLM_BASE_URL=

# ===== Zep Cloud メモリグラフ設定 =====
# 無料枠で簡単な利用には十分です: https://app.getzep.com/
ZEP_API_KEY=your_zep_api_key_here

# ===== 加速用 Gemini 設定（任意。並列シミュレーション時に 2 つ目の key を使う場合のみ）=====
# 加速設定を使わない場合は、以下の行ごと削除してください
LLM_BOOST_API_KEY=your_second_google_ai_api_key_here
LLM_BOOST_MODEL_NAME=gemini-3.1-flash-lite-preview
